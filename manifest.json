{
  "manifest_version": 3,
  "name": "AI Webpage Summarizer",
  "version": "1.0.0",
  "description": "Scrapes any webpage and summarizes it using an LLM API.",

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": [
        "src/content/scraper.js",
        "src/content/cleaner.js",
        "src/content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://localhost:3000/*"],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
